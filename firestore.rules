rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /rooms/{roomCode} {
      allow read, write: if isSignedIn();

      match /items/{itemId} {
        allow read, write: if isSignedIn();
      }

      match /ideas/{ideaId} {
        allow read, write: if isSignedIn();
      }

      match /expenses/{expenseId} {
        allow read, write: if isSignedIn();
      }

      match /members/{memberId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
